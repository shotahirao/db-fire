{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "db-fire",
  "version": "0.1.6",
  "identifier": "com.shotahirao.db-fire",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "db-fire",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/shotahirao/db-fire/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZDQTM4QURGNENGRENFQTUKUldTbHp2MU0zNHFqYkgwWW5TVWhJR2duVzVSSGVlS1NIQWw0UEJka2c0ZXJaaHFFL2wyWTFOZXAK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
